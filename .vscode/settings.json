{
  // ═══════════════════════════════════════════════════════════
  // Python — Interpreter & Environment
  // ═══════════════════════════════════════════════════════════
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,

  // ═══════════════════════════════════════════════════════════
  // Editor — General
  // ═══════════════════════════════════════════════════════════
  "editor.formatOnSave": true,
  "editor.rulers": [120],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // Sticky scroll — показывает текущий класс/функцию при прокрутке больших файлов
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  // Bracket pair guides — визуализация вложенности
  "editor.guides.bracketPairs": "active",
  "editor.bracketPairColorization.enabled": true,

  // ═══════════════════════════════════════════════════════════
  // Python Formatting — Ruff (matches pyproject.toml: line-length=120)
  // ═══════════════════════════════════════════════════════════
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ═══════════════════════════════════════════════════════════
  // JavaScript / TypeScript Formatting
  // ═══════════════════════════════════════════════════════════
  // Note: .prettierrc is in frontend/ — Prettier applies to frontend files only
  "prettier.requireConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ═══════════════════════════════════════════════════════════
  // YAML Schema associations
  // ═══════════════════════════════════════════════════════════
  "yaml.schemas": {
    "https://raw.githubusercontent.com/grafana/grafana/main/devenv/docker/provisioning/datasources/datasources.json": [
      "deployment/grafana/provisioning/datasources/*.yaml"
    ],
    "https://raw.githubusercontent.com/prometheus/prometheus/main/config/testdata/conf.good.yml": [
      "deployment/prometheus/*.yml",
      "deployment/prometheus/*.yaml"
    ]
  },

  // ═══════════════════════════════════════════════════════════
  // Git — Hide nested mcp-server repo from parent workspace view
  // ═══════════════════════════════════════════════════════════
  "git.ignoredRepositories": [
    "${workspaceFolder}/mcp-server"
  ],
  // Автоматически скрывать в Explorer всё из .gitignore
  "explorer.excludeGitIgnore": true,

  // ═══════════════════════════════════════════════════════════
  // File Watching — exclude heavy dirs to save CPU + RAM
  // ═══════════════════════════════════════════════════════════
  "files.watcherExclude": {
    "mcp-server/**": true,
    "**/.venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/node_modules/**": true,
    "**/logs/**": true,
    "**/build/**": true,
    "**/mcp-deepseek/**": true,
    "**/__pycache__/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/vscode-extension/**": true,
    "**/.cursor/**": true,
    "**/.vs/**": true,
    "**/bybit_strategy_tester.egg-info/**": true,
    "test_e2e_test_*/**": true,
    "test_eval_test_*/**": true,
    "test_memory_test_*/**": true,
    "**/agent_memory/**": true,
    "**/journal/**": true,
    "**/screenshots/**": true,
    "**/data/**": true,
    "**/temp_analysis/**": true
  },

  // ═══════════════════════════════════════════════════════════
  // Explorer — hide non-essential dirs from sidebar
  // ═══════════════════════════════════════════════════════════
  "files.exclude": {
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.pytest_cache": true,
    "**/mcp-deepseek": true,
    "**/__pycache__": true,
    "**/.cursor": true,
    "**/.vs": true,
    "**/bybit_strategy_tester.egg-info": true,
    "**/.cache": true,
    "test_e2e_test_*": true,
    "test_eval_test_*": true,
    "test_memory_test_*": true,
    "**/screenshots": true,
    "temp_analysis": true,
    ".run": true,
    "temp_*.py": true
  },

  // ═══════════════════════════════════════════════════════════
  // Search — exclude build artifacts and data dirs
  // ═══════════════════════════════════════════════════════════
  "search.exclude": {
    "mcp-server/**": true,
    "**/.venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/node_modules/**": true,
    "**/logs/**": true,
    "**/build/**": true,
    "**/mcp-deepseek/**": true,
    "**/__pycache__/**": true,
    "**/*.sqlite3": true,
    "**/*.sqlite3-wal": true,
    "**/*.sqlite3-shm": true,
    "**/vscode-extension/**": true,
    "**/.cursor/**": true,
    "**/.vs/**": true,
    "test_e2e_test_*/**": true,
    "test_eval_test_*/**": true,
    "test_memory_test_*/**": true,
    "**/screenshots/**": true,
    "**/data/**": true,
    "**/*.png": true,
    "**/*.jpg": true,
    "**/*.jpeg": true,
    "**/*.gif": true,
    "**/*.ico": true,
    "temp_analysis/**": true,
    ".run/**": true,
    "temp_*.py": true,
    "memory-bank/**": true
  },

  // ═══════════════════════════════════════════════════════════
  // Tasks
  // ═══════════════════════════════════════════════════════════
  "task.allowAutomaticTasks": "on",

  // ═══════════════════════════════════════════════════════════
  // Python Testing — pytest
  // ═══════════════════════════════════════════════════════════
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests",
    "--tb=short"
  ],

  // ═══════════════════════════════════════════════════════════
  // Pylance / Pyright — Type Checking
  // ═══════════════════════════════════════════════════════════
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.exclude": [
    "**/*.md",
    "**/*.MD",
    "mcp-server/**",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.mypy_cache/**",
    "test_e2e_test_*/**",
    "test_eval_test_*/**",
    "test_memory_test_*/**",
    "**/agent_memory/**",
    "**/journal/**",
    "**/node_modules/**",
    "**/logs/**",
    "**/data/**",
    "**/screenshots/**",
    "**/temp_analysis/**",
    "c:/Users/**",
    "C:/Users/**"
  ],
  // Suppress SQLAlchemy 1.x Column[] type mismatches (false positives)
  "python.analysis.diagnosticSeverityOverrides": {
    "reportArgumentType": "none",
    "reportReturnType": "none",
    "reportCallIssue": "warning",
    "reportAssignmentType": "warning"
  },

  // ═══════════════════════════════════════════════════════════
  // MyPy — disabled (Pylance + Ruff handle linting/types)
  // ═══════════════════════════════════════════════════════════
  "mypy-type-checker.enabled": false,

  // ═══════════════════════════════════════════════════════════
  // GitHub Copilot — Agent Mode
  // ═══════════════════════════════════════════════════════════
  "github.copilot.chat.agent.enabled": true,
  "chat.agent.maxRequests": 30,
  "chat.agent.runTasks": true,
  "chat.promptFiles": true,
  "github.copilot.chat.organizationCustomAgents.enabled": true,
  "chat.agentFilesLocations": [
    ".github/agents",
    ".agent"
  ],
  "chat.agentSkillsLocations": [
    ".github/skills"
  ],
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "python": true,
    "javascript": true,
    "html": true,
    "css": true,
    "json": true,
    "yaml": true
  },

  // ═══════════════════════════════════════════════════════════
  // Claude Code
  // ═══════════════════════════════════════════════════════════
  "claudeCode.useTerminal": true
}
